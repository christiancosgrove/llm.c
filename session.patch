diff --git a/doc/layernorm/layernorm.c b/doc/layernorm/layernorm.c
index 67aa40c..2c53276 100644
--- a/doc/layernorm/layernorm.c
+++ b/doc/layernorm/layernorm.c
@@ -9,36 +9,43 @@
 void layernorm_forward(float* out, float* mean, float* rstd,
                        float* inp, float* weight, float* bias,
                        int B, int T, int C) {
-    float eps = 1e-5f;
+    const float eps = 1e-5f;
+    const float inv_C = 1.0f / C;
+    
     for (int b = 0; b < B; b++) {
         for (int t = 0; t < T; t++) {
             // seek to the input position inp[b,t,:]
             float* x = inp + b * T * C + t * C;
-            // calculate the mean
+            float* out_bt = out + b * T * C + t * C;
+            
+            // calculate the mean and variance in one pass
             float m = 0.0f;
+            float v = 0.0f;
+            
+            // First pass: calculate mean
             for (int i = 0; i < C; i++) {
                 m += x[i];
             }
-            m = m/C;
-            // calculate the variance (without any bias correction)
-            float v = 0.0f;
+            m *= inv_C;
+            
+            // Second pass: calculate variance and apply normalization
+            float inv_std;
             for (int i = 0; i < C; i++) {
                 float xshift = x[i] - m;
                 v += xshift * xshift;
             }
-            v = v/C;
-            // calculate the rstd
-            float s = 1.0f / sqrtf(v + eps);
-            // seek to the output position in out[b,t,:]
-            float* out_bt = out + b * T * C + t * C;
+            v *= inv_C;
+            inv_std = 1.0f / sqrtf(v + eps);
+            
+            // Third pass: normalize and scale/shift
             for (int i = 0; i < C; i++) {
-                float n = (s * (x[i] - m)); // normalized output
-                float o = n * weight[i] + bias[i]; // scale and shift it
-                out_bt[i] = o; // write
+                float normalized = (x[i] - m) * inv_std;
+                out_bt[i] = normalized * weight[i] + bias[i];
             }
+            
             // cache the mean and rstd for the backward pass later
             mean[b * T + t] = m;
-            rstd[b * T + t] = s;
+            rstd[b * T + t] = inv_std;
         }
     }
 }
