@@ -9,33 +9,42 @@
 void layernorm_forward(float* out, float* mean, float* rstd,
                        float* inp, float* weight, float* bias,
                        int B, int T, int C) {
-    float eps = 1e-5f;
+    const float eps = 1e-5f;
+    const float inv_C = 1.0f / C;
+    
     for (int b = 0; b < B; b++) {
         for (int t = 0; t < T; t++) {
             // seek to the input position inp[b,t,:]
             float* x = inp + b * T * C + t * C;
-            // calculate the mean
+            float* out_bt = out + b * T * C + t * C;
+            
+            // calculate mean and variance in single pass
             float m = 0.0f;
+            float v = 0.0f;
+            
+            // First pass: calculate mean
             for (int i = 0; i < C; i++) {
                 m += x[i];
             }
-            m = m/C;
-            // calculate the variance (without any bias correction)
-            float v = 0.0f;
+            m *= inv_C;
+            
+            // Second pass: calculate variance and apply normalization
+            const float rsqrt_factor = 1.0f / sqrtf(eps); // pre-compute for potential early exit
             for (int i = 0; i < C; i++) {
                 float xshift = x[i] - m;
                 v += xshift * xshift;
             }
-            v = v/C;
+            v *= inv_C;
+            
             // calculate the rstd
             float s = 1.0f / sqrtf(v + eps);
-            // seek to the output position in out[b,t,:]
-            float* out_bt = out + b * T * C + t * C;
+            
+            // Third pass: normalize and scale
             for (int i = 0; i < C; i++) {
-                float n = (s * (x[i] - m)); // normalized output
-                float o = n * weight[i] + bias[i]; // scale and shift it
-                out_bt[i] = o; // write
+                float normalized = (x[i] - m) * s;
+                out_bt[i] = normalized * weight[i] + bias[i];
             }
+            
             // cache the mean and rstd for the backward pass later
             mean[b * T + t] = m;
             rstd[b * T + t] = s;
